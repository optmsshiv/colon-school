# Protect API folder - only allow PHP requests
Options -Indexes

# Block direct access to config.php
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# Only allow .php files
<FilesMatch "^(?!.*\.php$).*$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
</IfModule>
