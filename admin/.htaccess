# ============================================================
# Colonel's Sainik Vidyalaya — Admin Folder Protection
# ============================================================

# Block direct directory listing
Options -Indexes

# Deny access to this .htaccess file itself
<Files ".htaccess">
    Order allow,deny
    Deny from all
</Files>

# Force HTTPS for admin
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Optional: Restrict admin access to specific IP addresses
# Uncomment and replace with your actual IP to allow only your IP:
# <RequireAll>
#     Require ip 203.0.113.0
# </RequireAll>

# Security headers for admin
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set Cache-Control "no-store, no-cache, must-revalidate, private"
    Header always set Pragma "no-cache"
</IfModule>
